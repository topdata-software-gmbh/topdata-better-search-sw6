<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <!-- Autodiscovery -->
        <prototype namespace="Topdata\TopdataBetterSearchSW6\" resource="../../*" exclude="../../{DependencyInjection,Entity,Migration,Resources,TopdataBetterSearchSW6.php}" />

        <!-- Entity Definition -->
        <service id="Topdata\TopdataBetterSearchSW6\Entity\ZeroSearch\ZeroSearchDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <!-- Profile Registry (requires project dir for config loading) -->
        <service id="Topdata\TopdataBetterSearchSW6\Service\ProfileRegistry">
            <argument key="$projectDir">%kernel.project_dir%</argument>
        </service>
    </services>
</container>
